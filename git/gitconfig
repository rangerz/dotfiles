[core]
    editor = vim
    excludesfile = ~/.dotfiles/git/gitignore
[color]
    ui = auto
    diff = auto
    status = auto
    branch = auto
    log = auto
[alias]
    st = status
    ci = commit
    co = checkout
    c-p = cherry-pick
    br = branch
    df = diff
    dfc = diff --cached
    ll = log --stat
    la = log --graph --decorate --pretty=oneline --abbrev-commit --all
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    count = !git shortlog -sn
[commit]
    template = ~/.dotfiles/git/git_commit_templete
[log]
    date = iso
[gc]
    auto = 0
[help]
    #autocorrect = 1
[init]
    defaultBranch = main
[apply]
    whitespace = nowarn
[pull]
    rebase = true
[merge]
    ff = only
[rebase]
    autoStash = true
[push]
    autoSetupRemote = true
    default = simple
